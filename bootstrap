#!/usr/bin/env bash

set -euo pipefail

get_aur_helper() {
    local aur_helper="yay"

    echo "Installing AUR helper: $aur_helper"

    # Separate declaration with 'local' Bash builtin from the assignment,
    # since local masks the exit status of the substituted command.
    # A plain assignment does NOT mask the exit code.
    # See https://www.shellcheck.net/wiki/SC2155
    local build_dir
    build_dir=$(mktemp -d)

    if sudo pacman -S --needed --noconfirm git base-devel \
        && git clone https://aur.archlinux.org/yay-bin.git "$build_dir" \
        && (cd "$build_dir" && makepkg -si --noconfirm); then

        rm -rf "$build_dir"
        echo "$aur_helper installed successfully"
    else
        rm -rf "$build_dir"
        echo "Failed to install $aur_helper" >&2

        exit 1
    fi
}

# Official toolchain installer and manager for the Rust programming language
# Arch Linux official rust package and rustup conflict because they both provide executables like cargo and rustc
get_rustup() {
    if ! command -v rustup &>/dev/null; then
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y || {
            echo "Failed to fetch rustup installation script"
            return 1
        }
        . "$HOME/.cargo/env"
    fi
}

enable_services() {
    declare -a services=(keyd logid)

    echo "Enabling services: ${services[*]}"

    sudo systemctl enable --now "${services[@]}"
}

# System Dependencies
bootstrap_system() {
    # noto-fonts-emoji                  : Noto Color Emoji for Waybar
    # ttf-jetbrains-mono-nerd           : JetBrainsMono Nerd Font for Neovim
    sudo pacman -S --needed --noconfirm \
        ghostty \
        jless \
        keyd \
        mpv \
        niri fuzzel mako \
        noto-fonts-emoji \
        ripgrep \
        tmux \
        ttf-jetbrains-mono-nerd \
        vim neovim

    if ! command -v yay &>/dev/null; then
        get_aur_helper
    fi

    # yay options:
    #   --needed                        : Only install packages that are not already installed
    #   --noconfirm                     : Automatically answer "yes" to all confirmation prompts
    #   --answerdiff None               : Suppress the prompt to view the changes (diff) between the current PKGBUILD and the previously cached one
    #   --answerclean None              : After building an AUR package, answer "yes" to prompt to clean the build directory
    #
    # yay packages:
    #   logiops                         : Unofficial userspace driver for HID++ Logitech devices
    #   wlogout                         : Wayland based logout menu
    yay -S --needed --noconfirm --answerdiff None --answerclean None \
        logiops \
        wlogout

    get_rustup

    read -rp "Enable services? [Y/n] " response
    # test -z option catches empty response (just pressing Enter)
    if [[ -z "$response" || "${response,,}" == yes || "${response,,}" == y ]]; then
        enable_services
    fi
}
## Neovim
bootstrap_nvim() {
    sudo pacman -S --needed --noconfirm \
        fzf \
        gcc \
        git \
        go \
        jdk-openjdk \
        lua \
        maven \
        nodejs \
        npm \
        perl-tidy \
        python \
        python-pip \
        ripgrep \
        shellcheck \
        tree-sitter-cli \
        unzip \
        yazi

    get_rustup

    # Update Rust and install KDL LSP
    rustup update stable
    rustup component add rustfmt
    cargo install kdl-lsp
}

# Configs
bootstrap_configs() {
    DOTFILES="$(dirname "$(realpath "$0")")"
    CONFIG_HOME=$HOME/.config

    # Symlinks
    mkdir -p "$CONFIG_HOME/alacritty/" && ln -sfv "$DOTFILES/alacritty.toml" "$_"
    ln -sfv "$DOTFILES/Bash/bashrc" "$HOME/.bashrc"
    ln -sfv "$DOTFILES/Bash/bash_profile" "$HOME/.bash_profile"
    mkdir -p "$CONFIG_HOME/foot/" && ln -sfv "$DOTFILES/foot.conf" "$_/foot.ini"
    mkdir -p "$CONFIG_HOME/niri/" && ln -sfv "$DOTFILES/niri.kdl" "$_/config.kdl"
    mkdir -p "$CONFIG_HOME/mpv/" && ln -sfv "$DOTFILES/mpv/input.conf" "$_"
    ln -sfv "$DOTFILES/mpv/mpv.conf" "$CONFIG_HOME/mpv/"
    ln -sfv --no-dereference "$DOTFILES/Neovim" "$CONFIG_HOME/nvim" # Option --no-dereference prevents following of an existing symlink if it points to a directory
    ln -sfv "$DOTFILES/tmux.conf" "$HOME/.tmux.conf"
    ln -sfv "$DOTFILES/config.vim" "$HOME/.vimrc"
    ln -sfv "$DOTFILES/curlrc" "$HOME/.curlrc"
    sudo ln -sfv "$DOTFILES/logiops.conf" "/etc/logid.cfg"
    sudo ln -sfv "$DOTFILES/keyd.conf" "/etc/keyd/default.conf"
    mkdir -p "$CONFIG_HOME/waybar/" && ln -sfv "$DOTFILES/Waybar/config.jsonc" "$_" && ln -sfv "$DOTFILES/Waybar/style.css" "$_"
    mkdir -p "$CONFIG_HOME/rofi/" && ln -sfv "$DOTFILES/rofi.rasi" "$_/config.rasi"
}

case "${1:-}" in
    -a | --all)
        bootstrap_system
        bootstrap_nvim
        bootstrap_configs
        ;;
    -s | --system)
        bootstrap_system
        ;;
    --nvim)
        bootstrap_nvim
        ;;
    -c | --configs)
        bootstrap_configs
        ;;
    -h | --help)
        echo "Usage: ./bootstrap [option]"
        echo "      -a, --all           Install everything"
        echo "      -s, --system        Install system dependencies"
        echo "      -c, --configs       Install configs"
        echo "      --nvim              Install Neovim dependencies"
        ;;
    *)
        echo "Invalid option. See --help."
        exit 1
        ;;
esac
